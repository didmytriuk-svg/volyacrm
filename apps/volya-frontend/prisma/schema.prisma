// 1. Конфігурація генератора клієнта Prisma
generator client {
  provider = "prisma-client-js"
}

// 2. Блок підключення до бази даних (БЕЗ властивості url, як вимагає Prisma 7!)
datasource db {
  provider = "postgresql"
}

// ==========================================
// МОДЕЛІ ДЛЯ БІЗНЕС-ЛОГІКИ VOLYA.ACADEMIC
// ==========================================

// Перелік статусів для воронки лідів (CRM)
enum LeadStatus {
  NEW
  IN_PROGRESS
  TRIAL_SCHEDULED
  CONVERTED
  LOST
}

// Перелік основних предметів академії точних наук
enum SubjectType {
  MATHEMATICS
  PHYSICS
  CHEMISTRY
}

// Глобальні ролі користувачів у системі (RBAC)
enum Role {
  ADMIN
  MANAGER
  TEACHER
  STUDENT
}

// Модель для збору та обробки заявок з сайту
model Lead {
  id        String      @id @default(uuid())
  name      String
  phone     String
  subject   SubjectType @default(MATHEMATICS)
  status    LeadStatus  @default(NEW)
  notes     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // Індексація статусу для швидкого пошуку та рендерингу Kanban-дошки
  @@index([status])
}

// Глобальна модель користувача (адміни, менеджери, вчителі, учні)
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
