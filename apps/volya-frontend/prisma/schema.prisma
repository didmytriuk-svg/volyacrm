datasource db {
  provider = "postgresql"
  // Рядки підключення url та directUrl видалено звідси, бо Prisma 7 тепер вимагає їх у prisma.config.ts
}

generator client {
  provider = "prisma-client-js"
}

// Модель учня (Student)
model Student {
  id         String        @id @default(uuid())
  name       String
  phone      String
  grade      String        @default("11 клас")
  subject    String        @default("Математика")
  createdAt  DateTime      @default(now()) @map("created_at")
  notes      StudentNote[]

  @@map("students")
}

// Модель нотаток та завдань (StudentNote)
model StudentNote {
  id         String   @id @default(uuid())
  studentId  String?  @map("student_id")
  authorName String   @default("Адміністратор") @map("author_name")
  category   Category @default(GENERAL)
  text       String
  createdAt  DateTime @default(now()) @map("created_at")

  student    Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("student_notes")
}

enum Category {
  GENERAL
  ACADEMIC
  FINANCIAL
  SYSTEM
}
