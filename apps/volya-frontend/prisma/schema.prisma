datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Модель учня (Student)
model Student {
  id         String        @id @default(uuid())
  name       String
  phone      String
  grade      String        @default("11 клас")
  subject    String        @default("Математика")
  createdAt  DateTime      @default(now()) @map("created_at")
  notes      StudentNote[]

  @@map("students") // Примусово називаємо таблицю в Supabase як "students"
}

// Модель нотаток та завдань (StudentNote)
model StudentNote {
  id         String   @id @default(uuid())
  studentId  String?  @map("student_id")
  authorName String   @default("Адміністратор") @map("author_name")
  category   Category @default(GENERAL)
  text       String
  createdAt  DateTime @default(now()) @map("created_at")

  // Зв'язок із таблицею учнів (якщо studentId видалити, нотатка залишиться як глобальна)
  student    Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("student_notes") // Примусово називаємо таблицю в Supabase як "student_notes"
}

// Категорії для нотаток
enum Category {
  GENERAL
  ACADEMIC
  FINANCIAL
  SYSTEM
}
